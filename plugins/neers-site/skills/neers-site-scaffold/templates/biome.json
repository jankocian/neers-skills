{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/.next",
      "!**/next-env.d.ts",
      "!**/.neers",
      "!**/*.svg"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "assist": {
    "enabled": true,
    "actions": { "source": { "organizeImports": "on" } }
  },
  "linter": {
    "enabled": true,
    "domains": {
      "react": "recommended",
      "next": "recommended",
      "test": "recommended",
      "project": "none",
      "types": "none"
    },
    "rules": {
      "preset": "recommended",
      "nursery": {
        "useSortedClasses": {
          "level": "error",
          "fix": "safe",
          "options": { "functions": ["clsx", "cva", "cn", "twMerge"] }
        }
      }
    }
  },
  "javascript": {
    "formatter": { "quoteStyle": "double", "semicolons": "always" },
    "jsxRuntime": "transparent"
  },
  "css": {
    "parser": { "tailwindDirectives": true },
    "formatter": { "enabled": true },
    "linter": { "enabled": true }
  },
  "overrides": [
    {
      "includes": ["src/components/ui/**"],
      "linter": {
        "rules": {
          "a11y": {
            "noLabelWithoutControl": "off"
          }
        }
      }
    }
  ]
}
