{
  "name": "site",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.9.0"
  },
  "scripts": {
    "preinstall": "npx only-allow bun",
    "prepare": "lefthook install",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "biome check . && tsc --noEmit && bun tests/check-source.ts",
    "fix": "biome check --write . && tsc --noEmit",
    "test": "playwright test",
    "ci": "bun run check && CI=1 playwright test"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "yet-another-react-lightbox": "^3.32.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "^1.61.1",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cheerio": "^1.2.0",
    "lefthook": "^2.1.10",
    "schema-dts": "^2.0.0",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
